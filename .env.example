# ================================================================
# FLY NC — Variables de entorno
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el .env a git (está en .gitignore)
# ================================================================

# ── Base de datos ────────────────────────────────────────────────
DB_PASSWORD=cambia_esto_en_produccion
DB_HOST=postgres
DB_PORT=5432
DB_NAME=flync_db
DB_USER=flync_user

# ── Seguridad JWT ────────────────────────────────────────────────
# Genera claves seguras con: openssl rand -hex 64
JWT_SECRET=cambia_esto_es_un_secreto_muy_largo_y_seguro_de_al_menos_64_caracteres
JWT_REFRESH_SECRET=otro_secreto_diferente_muy_largo_y_seguro_para_refresh_tokens

# ── Frontend URL (donde estará publicado el frontend) ────────────
FRONTEND_URL=http://localhost:3000
# En producción: FRONTEND_URL=https://admin.flync.es

# ── API URL (para el frontend React) ────────────────────────────
REACT_APP_API_URL=http://localhost:3001
# En producción: REACT_APP_API_URL=https://api.flync.es

# ── Stripe (pagos online) ────────────────────────────────────────
# Obtén tus claves en: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── iMC² TSimplifica (control de acceso hardware) ───────────────
# API comprada: configura aquí las credenciales
IMC2_API_KEY=tu_api_key_de_imc2
IMC2_BASE_URL=https://api.imc2simplifica.com

# ── Email (para notificaciones y facturas) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=flync2009@gmail.com
SMTP_PASS=tu_app_password_gmail
SMTP_FROM=FLY NC <noreply@flync.es>

# ── Firebase (push notifications app móvil) ─────────────────────
# Configura en: https://console.firebase.google.com
FIREBASE_SERVER_KEY=
